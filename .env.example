# Copy this file to .env.local for local development
# Never commit .env.local — it's in .gitignore

# App
VITE_APP_NAME=AnnadathaBazar
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Feature flags
VITE_ENABLE_VOICE_SEARCH=true
VITE_ENABLE_WHATSAPP=true
VITE_ENABLE_GEOLOCATION=true
VITE_ENABLE_DEMO_DATA=true

# Official Open Government Data direct fallback for browser-only development.
# Production Azure Functions use DATA_GOV_IN_API_KEY instead.
VITE_DATA_GOV_IN_API_KEY=

# Azure Functions / server only
DATA_GOV_IN_API_KEY=

# Optional Function App phone OTP settings. Keep disabled with hosted auth.
OTP_PROVIDER=disabled
OTP_HASH_SECRET=
ACS_CONNECTION_STRING=
ACS_SMS_FROM=
NOTIFICATION_DELIVERY_MODE=in-app
