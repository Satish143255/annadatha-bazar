{
  "auth": {
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "entraExternalId": {
          "registration": {
            "clientIdSettingName": "ENTRA_EXTERNAL_ID_CLIENT_ID",
            "clientCredential": {
              "clientSecretSettingName": "ENTRA_EXTERNAL_ID_CLIENT_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://annadathabazarcustomers.ciamlogin.com/024f08ea-3967-40a2-a443-2147fcf8d78b/v2.0/.well-known/openid-configuration"
            }
          },
          "login": {
            "nameClaimType": "name",
            "scopes": ["openid", "profile", "email"]
          }
        }
      }
    }
  },
  "routes": [
    {
      "route": "/login",
      "redirect": "/.auth/login/entraExternalId?post_login_redirect_uri=https://jolly-sand-0207a2700.7.azurestaticapps.net/",
      "statusCode": 302
    },
    {
      "route": "/signup",
      "redirect": "/.auth/login/entraExternalId?post_login_redirect_uri=https://jolly-sand-0207a2700.7.azurestaticapps.net/",
      "statusCode": 302
    },
    {
      "route": "/forgot-password",
      "redirect": "/.auth/login/entraExternalId?post_login_redirect_uri=https://jolly-sand-0207a2700.7.azurestaticapps.net/",
      "statusCode": 302
    },
    {
      "route": "/reset-password",
      "redirect": "/.auth/login/entraExternalId?post_login_redirect_uri=https://jolly-sand-0207a2700.7.azurestaticapps.net/",
      "statusCode": 302
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout",
      "statusCode": 302
    },
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*.js",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*.css",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{js,css,png,jpg,svg,ico,json,woff,woff2}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "X-XSS-Protection": "1; mode=block",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=(self)"
  },
  "mimeTypes": {
    ".json": "text/json",
    ".woff2": "font/woff2"
  }
}
